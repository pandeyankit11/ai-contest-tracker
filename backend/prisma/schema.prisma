generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  password              String
  createdAt             DateTime               @default(now())
  contestAccounts       ContestAccount[]
  contestParticipations ContestParticipation[]
  ratingSnapshots       RatingSnapshot[]
  solvedProblems        SolvedProblem[]
  platformStats         PlatformStats[]
  username              String?
}

model ContestAccount {
  id        String   @id @default(cuid())
  userId    String
  platform  Platform
  handle    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
}

model Contest {
  id              String   @id @default(cuid())
  externalId      String   // CHANGED: Must be String to support LeetCode slugs
  platform        Platform
  name            String
  phase           ContestPhase
  startTime       DateTime
  endTime         DateTime
  durationSeconds Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  participations  ContestParticipation[]
  solvedProblems  SolvedProblem[]

  @@unique([platform, externalId])
  @@index([startTime])
  @@index([platform, startTime])
}

model RatingSnapshot {
  id         String   @id @default(cuid())
  userId     String
  platform   Platform
  rating     Int?
  maxRating  Int?
  rank       String?
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, recordedAt])
  @@index([userId, platform, recordedAt])
  @@index([platform, recordedAt])
}

model SolvedProblem {
  id         String   @id @default(cuid())
  userId     String
  contestId  String?
  platform   Platform
  externalId String
  name       String
  url        String?
  tags       String[] @default([])
  difficulty String?
  rating     Int?
  solvedAt   DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  contest    Contest? @relation(fields: [contestId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, externalId])
  @@index([userId, platform, solvedAt])
  @@index([platform, solvedAt])
  @@index([contestId])
  @@index([platform, difficulty])
  @@index([platform, rating])
}

model ContestParticipation {
  id                String   @id @default(cuid())
  userId            String
  contestId         String?
  platform          Platform
  externalContestId String
  rank              Int?
  oldRating         Int?
  newRating         Int?
  ratingChange      Int?
  problemsSolved    Int      @default(0)
  penalty           Int?
  participatedAt    DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  contest           Contest? @relation(fields: [contestId], references: [id])
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, externalContestId])
  @@index([userId, platform, participatedAt])
  @@index([platform, participatedAt])
  @@index([contestId])
  @@index([userId, platform, ratingChange])
}

model PlatformStats {
  id        String   @id @default(cuid())
  userId    String
  platform  Platform
  easy      Int      @default(0)
  medium    Int      @default(0)
  hard      Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

enum Platform {
  CODEFORCES
  LEETCODE
  CODECHEF
}

enum ContestPhase {
  BEFORE
  CODING
  PENDING_SYSTEM_TEST
  SYSTEM_TEST
  FINISHED
}